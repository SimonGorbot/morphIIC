    {
      "addr": 17,
      "default": 161,
      "access": "ro",
      "name": "HOST",
      "csv": {
        "path": "csv/host.csv",
        "mode": "host_stream"
      }
    },
    {
      "addr": 1,
      "default": 52,
      "access": "ro",
      "name": "ID1"
    },
    {
      "addr": 16,
      "default": 0,
      "access": "rw",
      "name": "RW0"
    }
  ]
}